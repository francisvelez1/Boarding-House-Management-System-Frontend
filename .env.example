# ================================================================
# ResidEase — Frontend Environment Variables
# ================================================================
# HOW TO USE:
#   1. Copy this file and rename it to ".env"
#   2. Fill in your real values below
#   3. NEVER commit .env to Git — add it to .gitignore
# ================================================================

# ── API ──────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080/api

# ── App ──────────────────────────────────────────────────────────
VITE_FRONTEND_URL=http://localhost:5173
VITE_APP_NAME="ResidEase"
VITE_APP_ENV=development

# ── Google OAuth ─────────────────────────────────────────────────
# Must match GOOGLE_CLIENT_ID in backend .env
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com